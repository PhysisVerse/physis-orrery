{
  "name": "physis-orrery",
  "version": "0.1.0",
  "private": true,
  "description": "Orrery: Physis on-chain program suite",
  "scripts": {
    "build": "anchor build",
    "idl:eligibility": "bash scripts/idl/regenerate-eligibility-types.sh",
    "test": "anchor test",
    "test:ts": "ts-mocha -p ./tsconfig.json -t 1000000 tests/physis_epoch_registry.spec.ts tests/physis_eligibility_registry.spec.ts tests/physis_eligibility_registry.pause.spec.ts tests/physis_eligibility_registry.authority.spec.ts tests/physis_eligibility_registry.hardening.spec.ts tests/physis_eligibility_registry.transitions.spec.ts tests/physis_eligibility_registry.events.spec.ts tests/physis_eligibility_registry.class-invariants.spec.ts tests/physis_eligibility_registry.binding.spec.ts tests/physis_eligibility_registry.record-policy.spec.ts tests/physis_eligibility_registry.upsert-status.spec.ts tests/physis_eligibility_registry.issuer-grant.spec.ts tests/physis_eligibility_registry.delegated-upsert.spec.ts tests/physis_eligibility_registry.root-authority-upsert.spec.ts",
    "test:prive:offchain": "ts-mocha -p ./tsconfig.json -t 10000 tests/prive-ownership.spec.ts tests/prive-sync-policy.spec.ts",
    "test:persona:offchain": "ts-mocha -p ./tsconfig.json -t 10000 tests/persona-attestation.spec.ts tests/persona-sync-policy.spec.ts",
    "script:eligibility:sync-prive:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json node --env-file=.env --import tsx scripts/localnet/sync-prive-holder.ts",
    "script:init:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/localnet/initialize-registry.ts",
    "script:epoch:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/localnet/register-current-epoch.ts",
    "script:activate:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/localnet/activate-current-epoch.ts",
    "script:status:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/localnet/status.ts",
    "script:init:devnet": "ANCHOR_PROVIDER_URL=$HELIUS_DEVNET_RPC ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/devnet/initialize-registry.ts",
    "script:epoch:devnet": "ANCHOR_PROVIDER_URL=$HELIUS_DEVNET_RPC ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/devnet/register-current-epoch.ts",
    "script:activate:devnet": "ANCHOR_PROVIDER_URL=$HELIUS_DEVNET_RPC ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/devnet/activate-current-epoch.ts",
    "script:status:devnet": "ANCHOR_PROVIDER_URL=$HELIUS_DEVNET_RPC ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/devnet/status.ts",
    "script:bootstrap:devnet": "yarn script:init:devnet && yarn script:epoch:devnet && yarn script:status:devnet",
    "script:eligibility:init:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/localnet/initialize-eligibility-registry.ts",
    "script:eligibility:classes:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/localnet/bootstrap-eligibility-classes.ts",
    "script:eligibility:status:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/localnet/eligibility-status.ts",
    "script:eligibility:bootstrap:local": "yarn script:eligibility:init:local && yarn script:eligibility:classes:local && yarn script:eligibility:status:local",
    "script:eligibility:lifecycle:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/localnet/eligibility-record-lifecycle.ts",
    "lint": "cargo fmt --all -- --check && cargo clippy -p physis_eligibility_registry --all-targets -- -D warnings",
    "fmt": "cargo fmt --all"
  },
  "devDependencies": {
    "@anchor-lang/core": "^1.1.2",
    "@solana-program/program-metadata": "^0.7.0",
    "@solana/kit": "^7.0.0",
    "@solana/web3.js": "^1.98.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "mocha": "^11.7.6",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0"
  }
}
