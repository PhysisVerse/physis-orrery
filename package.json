{
  "name": "physis-orrery",
  "version": "0.1.0",
  "private": true,
  "description": "Orrery: Physis on-chain program suite",
  "scripts": {
      "build": "anchor build",
      "test": "anchor test",
      "test:ts": "ts-mocha -p ./tsconfig.json -t 1000000 tests/physis_epoch_registry.spec.ts",
      "script:init:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/localnet/initialize-registry.ts",
      "script:epoch:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/localnet/register-current-epoch.ts",
      "script:activate:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/localnet/activate-current-epoch.ts",
      "script:status:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json tsx scripts/localnet/status.ts",
      "lint": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D warnings",
      "fmt": "cargo fmt --all"
  },
  "devDependencies": {
    "@anchor-lang/core": "^1.1.2",
    "@solana/web3.js": "^1.98.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "mocha": "^11.7.6",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0"
  }
}
